[
    {
        "Effect": "Deny",
        "Action": [
            "secretsmanager:DeleteSecret"
        ],
        "Resource": [
            "arn:aws:secretsmanager:*:*:secret:rds!cluster-*",
            "arn:aws:secretsmanager:*:*:secret:rds!db-*"
        ],
        "Condition": {
            "ArnNotLike": {
                "aws:PrincipalARN": [
                    "arn:*:iam::*:role/aws-hcp-deployment-role"
                ]
            }
        }
    }
]