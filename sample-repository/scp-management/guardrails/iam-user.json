[
  {
    "Effect": "Deny",
    "Action": [
      "iam:CreateAccessKey",
      "iam:CreateUser",
      "iam:UpdateLoginProfile",
      "iam:CreateLoginProfile",
      "iam:DeleteLoginProfile"
    ],
    "Resource": "*",
    "Condition": {
      "ArnNotLike": {
        "aws:PrincipalARN": [
          "arn:*:iam::*:role/AWSControlTowerExecution",
          "arn:*:iam::*:role/AWSAFTExecution",
          "arn:*:iam::*:role/Admin"
        ]
      }
    }
  }
]