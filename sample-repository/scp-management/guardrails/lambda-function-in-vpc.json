[
  {
    "Sid": "DenyLambdaWithoutVPC",
    "Effect": "Deny",
    "Action": [
      "lambda:CreateFunction",
      "lambda:UpdateFunctionConfiguration"
    ],
    "Resource": "*",
    "Condition": {
      "Null": {
        "lambda:VpcIds": "true"
      },
      "ArnNotLike": {
        "aws:PrincipalARN": [
          "arn:*:iam::*:role/AWSControlTowerExecution",
          "arn:*:iam::*:role/AWSAFTExecution",
          "arn:*:iam::*:role/Admin"
        ]
      }
    }
  }
]