[
  {
    "Effect": "Deny",
    "Action": [
      "ec2:CreateKeyPair"
    ],
    "Resource": [
      "*"
    ],
    "Condition": {
      "ArnNotLike": {
        "aws:PrincipalARN": [
          "arn:aws:iam::*:role/AWSControlTowerExecution",
          "arn:aws:iam::*:role/AWSAFTExecution",
          "arn:aws:iam::*:role/Admin"
        ]
      }
    }
  },
  {
    "Effect": "Deny",
    "Action": [
      "ec2:RunInstances"
    ],
    "Resource": "*",
    "Condition": {
      "Null": {
        "ec2:KeyPairName": "false"
      }
    }
  }
]