[
  {
    "Effect": "Deny",
    "Action": "sns:Subscribe",
    "Resource": "*",
    "Condition": {
      "StringNotLike": {
        "sns:Endpoint": [
          "*@amazon.com"
        ]
      },
      "StringLike": {
        "sns:Protocol": [
          "email",
          "email-json"
        ]
      }
    }
  }
]