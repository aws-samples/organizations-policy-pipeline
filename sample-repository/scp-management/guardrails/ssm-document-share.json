[
  {
    "Effect": "Deny",
    "Action": [
      "ssm:UpdateServiceSetting",
      "ssm:ResetServiceSetting"
    ],
    "Resource": "arn:aws:ssm:*:*:servicesetting/ssm/documents/console/public-sharing-permission",
    "Condition": {
      "ArnNotLike": {
        "aws:PrincipalARN": [
          "arn:*:iam::*:role/AWSControlTowerExecution",
          "arn:*:iam::*:role/AWSAFTExecution",
          "arn:*:iam::*:role/Admin"
        ]
      }
    }
  }
]